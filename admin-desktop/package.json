{
  "name": "kl-ai-quiz-admin-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"vite --port 5190 --strictPort\" \"wait-on tcp:127.0.0.1:5190 && electron electron/main.cjs\"",
    "build": "tsc --noEmit && vite build",
    "start": "electron electron/main.cjs",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "edu.kl.quizadmin",
    "productName": "KL AI Quiz Admin",
    "files": ["dist/**", "electron/**"],
    "directories": { "output": "release" },
    "win": { "target": "nsis" }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
