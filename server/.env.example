# Copy to server/.env and fill in. NEVER commit the real key.
ANTHROPIC_API_KEY=sk-ant-...
# Model used to generate the MCQ bank (Haiku is cheapest; you chose Haiku).
CLAUDE_MODEL=claude-haiku-4-5
# Simple gate for the admin (bank-generation) endpoints. Change this.
ADMIN_TOKEN=change-me-admin
# Backend port (the Vite dev server proxies /api here).
PORT=4000

# ---- Storage backend ----
# json  = local dev, stores in server/data/*.json (default)
# mysql = production (Hostinger VPS). Fill the DB_* values below.
DB_DRIVER=json
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=quiz_user
DB_PASSWORD=
DB_NAME=kl_ai_quiz
# Set DB_SSL=true only if your MySQL requires TLS.
DB_SSL=false
# How many questions each student gets.
QUIZ_SIZE=60
# Exam duration in minutes. The exam auto-submits when time runs out.
QUIZ_DURATION_MIN=60
